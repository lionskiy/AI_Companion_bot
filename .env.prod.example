# ── Mirror Production Environment ──────────────────────────────────
# Copy to .env.prod on the server and fill in real values.
# NEVER commit .env.prod to git.

PROD_DOMAIN=YOUR_SUBDOMAIN.YOUR_DOMAIN.TLD

# PostgreSQL
POSTGRES_USER=mirror
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=mirror

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# RabbitMQ
RABBITMQ_USER=mirror
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# LLM API keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME

# JWT
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_STRING

# Appsmith (if used)
APPSMITH_ENCRYPTION_PASSWORD=CHANGE_ME
APPSMITH_ENCRYPTION_SALT=CHANGE_ME
