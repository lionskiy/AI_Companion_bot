# App
APP_ENV=development
SECRET_KEY=your-secret-key-min-32-chars
BASE_URL=https://your-ngrok-or-domain.com

# PostgreSQL (local dev: localhost:19102)
DATABASE_URL=postgresql+asyncpg://mirror:mirror@localhost:19102/mirror
TEST_DATABASE_URL=postgresql+asyncpg://mirror:mirror@localhost:19102/mirror_test

# Redis (local dev: localhost:19103)
REDIS_URL=redis://localhost:19103/0

# Qdrant (local dev: localhost:19104)
QDRANT_URL=http://localhost:19104
QDRANT_API_KEY=

# RabbitMQ (local dev: localhost:19106)
RABBITMQ_URL=amqp://guest:guest@localhost:19106/

# NATS (local dev: localhost:19108)
NATS_URL=nats://localhost:19108

# LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-min-32-chars

# Admin
ADMIN_TOKEN=your-admin-token-min-32-chars

# Appsmith (local dev: http://localhost:19101)
APPSMITH_ENCRYPTION_PASSWORD=your-appsmith-password
APPSMITH_ENCRYPTION_SALT=your-appsmith-salt
APPSMITH_DB_URL=postgresql://appsmith_ro:appsmith_password@localhost:19102/mirror

# Sentry (опционально)
SENTRY_DSN=
